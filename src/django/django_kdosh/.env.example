# Copy this file to .env and fill in the values.
# .env is git-ignored; .env.example is committed as a template.

# Django
DEBUG=True
# When True, Django uses the local sqlite db (db.sqlite3) instead of Postgres.
DEVELOPMENT_MODE=True

# PostgreSQL (analytics / Odoo databases)
PG_NAME_V11=
PG_NAME_V15=
PG_NAME_V17=
PG_USER=
PG_HOST=
PG_PWD=

# Odoo XML-RPC
ODOO_URL=
ODOO_DB=
ODOO_PWD=
ODOO_UID=
